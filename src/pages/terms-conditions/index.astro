---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Terms & Conditions — Odyssey Homes">
  <Header />

  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <h1 class="text-4xl lg:text-5xl font-bold tracking-tight text-odyssey-charcoal">Terms &amp; Conditions</h1>
      <div class="mt-10 space-y-6 text-odyssey-stone-dark leading-relaxed">
        <p>
          Welcome to the Odyssey Homes website. By accessing this site, you agree to be bound by the terms and conditions described here. The content of this website is for general information only.
        </p>
        <h2 class="text-2xl font-semibold text-odyssey-charcoal mt-10">Use of materials</h2>
        <p>
          All content on this site — including plan renderings, photographs, and copy — is the property of Odyssey Homes and is not to be reproduced without permission.
        </p>
        <h2 class="text-2xl font-semibold text-odyssey-charcoal mt-10">Information accuracy</h2>
        <p>
          Floor plans, square footage, finishes, and pricing are subject to change and are not contractual. Renderings and photographs may show optional features or upgrades not included in the standard plan.
        </p>
        <h2 class="text-2xl font-semibold text-odyssey-charcoal mt-10">Privacy</h2>
        <p>
          Information you submit through our contact forms is used solely to respond to your inquiry. We do not sell or share your information with third parties.
        </p>
        <h2 class="text-2xl font-semibold text-odyssey-charcoal mt-10">Contact</h2>
        <p>
          Questions about these terms? Reach us at <a href="mailto:office@buildodyssey.com" class="text-odyssey-accent hover:underline">office@buildodyssey.com</a> or (208) 450-5500.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
