---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactForm from '../components/ContactForm.astro';
import VisitUs from '../components/VisitUs.astro';
import { livePlans } from '../data/plans';
import { communities } from '../data/communities';
import { site } from '../data/site';

const featuredPlans = livePlans.slice(0, 3);
---

<Layout>
  <Header />

  <!-- Hero -->
  <section class="relative bg-odyssey-charcoal overflow-hidden">
    <div class="absolute inset-0">
      <img src="/media/g2hfvs3i/odyssey-homes-idaho-falls.jpg" alt="" class="w-full h-full object-cover opacity-50" />
      <div class="absolute inset-0 bg-gradient-to-r from-odyssey-charcoal/85 via-odyssey-charcoal/55 to-odyssey-charcoal/30"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-8 py-28 lg:py-44">
      <p class="hero-eyebrow text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Eastern Idaho · New Construction Homes</p>
      <h1 class="hero-headline mt-6 text-5xl lg:text-7xl font-bold tracking-tight max-w-4xl leading-[1.05] text-white">
        {site.tagline}
      </h1>
      <p class="hero-sub mt-8 text-xl lg:text-2xl text-odyssey-cream/90 max-w-2xl leading-relaxed">
        Building your dream home should be an inspiring and seamless experience.
      </p>
      <div class="hero-ctas mt-12 flex flex-wrap gap-4">
        <a href="/semi-custom-home-floor-plans/" class="cta-pulse inline-block bg-odyssey-accent hover:bg-odyssey-accent-deep text-white font-semibold py-3 px-7 rounded transition-colors">
          Browse Floor Plans
        </a>
        <a href="/lets-talk/" class="inline-block bg-white/10 hover:bg-white/20 backdrop-blur text-white font-semibold py-3 px-7 rounded transition-colors border border-white/20">
          Let's Talk
        </a>
      </div>
      <p class="hero-rate mt-10 text-sm text-odyssey-cream/80">
        Today's interest rate: <span class="font-bold text-odyssey-accent-light">{site.interestRate}</span>
      </p>
    </div>
  </section>

  <!-- Service area strip — Eastern Idaho positioning -->
  <section class="bg-odyssey-charcoal text-odyssey-cream py-8 border-t border-odyssey-cream/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 text-center">
      <p class="text-sm uppercase tracking-widest text-odyssey-accent-light font-semibold">
        Building Across Eastern Idaho
      </p>
      <p class="mt-3 text-lg">
        Idaho Falls · Ammon · Rigby · Rexburg · Shelley · Blackfoot
      </p>
      <p class="mt-2 text-sm text-odyssey-cream/70">
        New construction only — we don't do remodels or additions.
      </p>
    </div>
  </section>

  <!-- Why Odyssey -->
  <section class="bg-odyssey-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Crafting Beautiful, Semi-Custom Homes</p>
      <h2 class="mt-4 text-4xl lg:text-5xl font-semibold tracking-tight max-w-3xl text-odyssey-charcoal">Why Choose Odyssey Homes?</h2>

      <div class="mt-16 grid md:grid-cols-2 gap-12">
        <div>
          <div class="h-[3px] w-12 bg-odyssey-accent mb-6"></div>
          <h3 class="text-2xl font-semibold text-odyssey-charcoal">Semi-Custom Builds Tailored to You</h3>
          <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
            Start with one of our floor plans, then make it your own. Three exterior styles, your choice of finishes, and a team that walks you through every selection.
          </p>
        </div>
        <div>
          <div class="h-[3px] w-12 bg-odyssey-accent mb-6"></div>
          <h3 class="text-2xl font-semibold text-odyssey-charcoal">A Knowledgeable Team to Guide You</h3>
          <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
            When you work with Odyssey, you get the undivided attention of our draftsman, designer, builders, and agents — fully involved from estimating through close-out.
          </p>
        </div>
        <div>
          <div class="h-[3px] w-12 bg-odyssey-accent mb-6"></div>
          <h3 class="text-2xl font-semibold text-odyssey-charcoal">Effortless Customization &amp; Finishing Touches</h3>
          <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
            Cabinet styles, countertops, flooring, lighting, fixtures — every decision is captured in our digital selection portal so you always know where things stand.
          </p>
        </div>
        <div>
          <div class="h-[3px] w-12 bg-odyssey-accent mb-6"></div>
          <h3 class="text-2xl font-semibold text-odyssey-charcoal">Thoughtfully Designed for Life in Eastern Idaho</h3>
          <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
            Plans built for Eastern Idaho — from Idaho Falls to Rexburg, Shelley to Blackfoot. Heated garages, finished basements, mudrooms that work in winter, outdoor spaces that come alive in summer.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Plans -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Floor Plans</p>
      <h2 class="mt-4 text-4xl lg:text-5xl font-semibold tracking-tight max-w-3xl text-odyssey-charcoal">Browse Our Customizable Floor Plans</h2>
      <p class="mt-4 text-odyssey-stone-dark max-w-2xl leading-relaxed">
        Twelve base plans, three exterior styles each. Pick one, make it yours.
      </p>

      <div class="mt-12 grid md:grid-cols-3 gap-8">
        {featuredPlans.map(plan => (
          <a href={`/semi-custom-home-floor-plans/${plan.slug}/`} class="group block bg-odyssey-bone rounded overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-[4/3] bg-odyssey-sand overflow-hidden">
              {plan.exteriorImage && (
                <img src={plan.exteriorImage} alt={plan.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
              )}
            </div>
            <div class="p-6">
              <h3 class="text-2xl font-semibold text-odyssey-charcoal">{plan.name}</h3>
              <p class="mt-2 text-sm text-odyssey-stone">{plan.totalSqFt?.toLocaleString()} sq ft · {plan.beds} bed · {plan.baths} bath</p>
              <p class="mt-3 text-sm text-odyssey-stone-dark leading-relaxed">{plan.shortDescription}</p>
              <p class="mt-4 text-sm font-semibold text-odyssey-accent uppercase tracking-wider">View plan →</p>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-12">
        <a href="/semi-custom-home-floor-plans/" class="inline-block bg-odyssey-charcoal hover:bg-odyssey-stone-dark text-white font-semibold py-3 px-7 rounded transition-colors">
          See All Floor Plans
        </a>
      </div>
    </div>
  </section>

  <!-- Communities -->
  <section class="bg-odyssey-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Communities</p>
      <h2 class="mt-4 text-4xl lg:text-5xl font-semibold tracking-tight max-w-3xl text-odyssey-charcoal">Discover Our Communities</h2>
      <p class="mt-4 text-odyssey-stone-dark max-w-2xl leading-relaxed">
        Find the best location for your semi-custom home.
      </p>

      <div class="mt-12 grid md:grid-cols-3 gap-8">
        {communities.map(c => (
          <div class="group bg-white rounded overflow-hidden hover:shadow-lg transition-shadow">
            <div class="aspect-[4/3] bg-odyssey-sand overflow-hidden">
              <img src={c.image} alt={c.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="p-6">
              <div class="flex items-center justify-between">
                <h3 class="text-2xl font-semibold text-odyssey-charcoal">{c.name}</h3>
                {c.status === 'coming-soon' && (
                  <span class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent">Coming Soon</span>
                )}
              </div>
              <p class="mt-3 text-sm text-odyssey-stone-dark leading-relaxed">{c.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Cross-promo to Guardian — locked link per Curtis -->
  <section class="bg-odyssey-stone-dark text-odyssey-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Looking for a fully custom home?</p>
        <h2 class="mt-4 text-3xl lg:text-4xl font-semibold tracking-tight text-white">Visit our affiliated luxury brand.</h2>
        <p class="mt-4 text-odyssey-cream/85 leading-relaxed">
          {site.affiliate.description}
        </p>
        <a href={site.affiliate.href} target="_blank" rel="noopener" class="mt-8 inline-block bg-odyssey-accent hover:bg-odyssey-accent-deep text-white font-semibold py-3 px-7 rounded transition-colors">
          Visit {site.affiliate.name} →
        </a>
      </div>
      <div class="grid grid-cols-3 gap-3">
        <img src="/media/dwekiobk/custom-home-4.jpg" alt="" class="aspect-square object-cover rounded" />
        <img src="/media/benn0uua/custom-home-5.jpg" alt="" class="aspect-square object-cover rounded" />
        <img src="/media/44ubcln0/custom-home-6.jpg" alt="" class="aspect-square object-cover rounded" />
        <img src="/media/qrkguqcy/custom-home-2.jpg" alt="" class="aspect-square object-cover rounded" />
        <img src="/media/savnoyr0/custom-home-3.jpg" alt="" class="aspect-square object-cover rounded" />
        <img src="/media/xkllvuu1/ashwood-2021-4-scaled.jpg" alt="" class="aspect-square object-cover rounded" />
      </div>
    </div>
  </section>

  <!-- Visit Us (Showroom) -->
  <VisitUs variant="section" />

  <!-- Out-of-state buyer welcome -->
  <section class="bg-odyssey-bone">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20 text-center">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Moving to Eastern Idaho?</p>
      <h2 class="mt-4 text-3xl lg:text-4xl font-semibold tracking-tight text-odyssey-charcoal">
        Building from out of state? We've got you.
      </h2>
      <p class="mt-6 text-lg text-odyssey-stone-dark leading-relaxed max-w-3xl mx-auto">
        A good portion of our buyers are relocating to Eastern Idaho from out of state. We handle virtual selection meetings, video walkthroughs, and digital signoffs through our client portal — so you can build with confidence even if you can't be on-site every week. Talk to us about your move.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/moving-to-eastern-idaho/" class="inline-block bg-odyssey-accent hover:bg-odyssey-accent-deep text-white font-semibold py-3 px-7 rounded transition-colors">
          Read Our Relocation Guide
        </a>
        <a href="/lets-talk/" class="inline-block bg-white hover:bg-odyssey-sand text-odyssey-charcoal font-semibold py-3 px-7 rounded border border-odyssey-stone/30 transition-colors">
          Tell Us About Your Move
        </a>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="bg-white">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 lg:py-32 grid md:grid-cols-2 gap-16 items-start">
      <div>
        <ContactForm
          heading="Ready to Build Your Eastern Idaho Home?"
          intro="Send us a message and one of our Project Consultants will be in touch."
        />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent">Visit Us Today</p>
        <h3 class="mt-3 text-2xl font-semibold text-odyssey-charcoal">Schedule a Meeting</h3>
        <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
          Stop by our Ammon office, or call ahead to set a time.
        </p>
        <div class="mt-8 space-y-6">
          {site.addresses.map(addr => (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">Office</p>
              <p class="mt-1 text-odyssey-stone-dark">{addr.line1}<br />{addr.line2}</p>
            </div>
          ))}
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">Phone</p>
            <p class="mt-1 text-odyssey-stone-dark"><a href={site.phoneHref} class="hover:text-odyssey-accent">{site.phone}</a></p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">Email</p>
            <p class="mt-1 text-odyssey-stone-dark"><a href={site.emailHref} class="hover:text-odyssey-accent">{site.email}</a></p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
