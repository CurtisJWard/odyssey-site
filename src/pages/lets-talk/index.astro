---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import { site } from '../../data/site';
---

<Layout title="Let's Talk — Odyssey Homes" description="Get the conversation started about building a new construction home across Eastern Idaho — Idaho Falls, Ammon, Rigby, Rexburg, Shelley, and Blackfoot.">
  <Header />

  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Let's Talk</p>
      <h1 class="mt-4 text-4xl lg:text-5xl font-bold tracking-tight text-white max-w-3xl leading-tight">
        Let's get the conversation started about building and designing your home in one of our exclusive custom communities.
      </h1>
      <p class="mt-6 text-lg text-odyssey-cream/85 max-w-2xl leading-relaxed">
        When working with Odyssey Homes you will get the undivided attention of our professional draftsman, designer, builders, and agents. We are fully involved in everything from estimating, scheduling, and managing your project from start to finish.
      </p>
    </div>
  </section>

  <section class="bg-odyssey-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <ContactForm heading="Send us a message" intro="" />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent">Or reach out directly</p>
        <h3 class="mt-3 text-2xl font-semibold text-odyssey-charcoal">We'd love to hear from you.</h3>
        <div class="mt-8 space-y-6">
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">Phone</p>
            <p class="mt-1"><a href={site.phoneHref} class="text-2xl font-semibold text-odyssey-charcoal hover:text-odyssey-accent transition-colors">{site.phone}</a></p>
          </div>
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">Email</p>
            <p class="mt-1"><a href={site.emailHref} class="text-lg text-odyssey-charcoal hover:text-odyssey-accent transition-colors">{site.email}</a></p>
          </div>
          {site.addresses.map(addr => (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">Office</p>
              <p class="mt-1 text-odyssey-stone-dark">{addr.line1}<br />{addr.line2}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
