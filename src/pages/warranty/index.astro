---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Warranty — Odyssey Homes" description="Odyssey Homes uses 2-10 Home Buyers Warranty. Submit non-emergency requests at the 1st and 10th month anniversaries.">
  <Header />

  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Warranty</p>
      <h1 class="mt-4 text-4xl lg:text-6xl font-bold tracking-tight text-white">2-10 Home Buyers Warranty</h1>
      <p class="mt-6 text-lg text-odyssey-cream/85 max-w-2xl leading-relaxed">
        Odyssey Homes uses 2-10 Home Buyers Warranty for coverage. Submit non-emergency requests at the 1st and 10th month anniversaries.
      </p>
    </div>
  </section>

  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-20">
      <h2 class="text-3xl font-semibold text-odyssey-charcoal">How to submit a warranty request</h2>
      <ol class="mt-8 space-y-6">
        <li class="flex gap-4">
          <span class="shrink-0 w-9 h-9 rounded-full bg-odyssey-accent text-white font-bold flex items-center justify-center">1</span>
          <div>
            <p class="font-semibold text-odyssey-charcoal">Visit <a href="https://www.2-10.com" target="_blank" rel="noopener" class="text-odyssey-accent hover:underline">2-10.com</a> and sign in.</p>
            <p class="mt-1 text-sm text-odyssey-stone-dark">New users register under the Homeowner tab.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-9 h-9 rounded-full bg-odyssey-accent text-white font-bold flex items-center justify-center">2</span>
          <div>
            <p class="font-semibold text-odyssey-charcoal">Select Service Requests.</p>
            <p class="mt-1 text-sm text-odyssey-stone-dark">Build your list of items needing service.</p>
          </div>
        </li>
        <li class="flex gap-4">
          <span class="shrink-0 w-9 h-9 rounded-full bg-odyssey-accent text-white font-bold flex items-center justify-center">3</span>
          <div>
            <p class="font-semibold text-odyssey-charcoal">Submit for processing.</p>
            <p class="mt-1 text-sm text-odyssey-stone-dark">A FLWS team member will contact both you and Odyssey Homes to coordinate the work.</p>
          </div>
        </li>
      </ol>

      <div class="mt-12 bg-odyssey-bone rounded p-6">
        <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent">2-10 portal support</p>
        <p class="mt-3 text-odyssey-stone-dark">
          For portal access issues, call <a href="tel:18008118787" class="text-odyssey-accent hover:underline">1.800.811.8787</a> or email <a href="mailto:FLWS@2-10.com" class="text-odyssey-accent hover:underline">FLWS@2-10.com</a>.
        </p>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
