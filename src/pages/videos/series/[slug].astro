---
import Layout from '../../../layouts/Layout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { series, videosInSeries, type VideoSeries } from '../../../data/series';
import { videoThumbnail } from '../../../data/videos';

export function getStaticPaths() {
  return series.map(s => ({
    params: { slug: s.slug },
    props: { seriesData: s },
  }));
}

interface Props { seriesData: VideoSeries }
const { seriesData } = Astro.props;

const episodes = videosInSeries(seriesData.slug);
const hasEpisodes = episodes.length > 0;

// Schema for the series — treated as a CourseInstance / VideoObject collection
const BASE_URL = 'https://buildodyssey.com';
const seriesUrl = `${BASE_URL}/videos/series/${seriesData.slug}/`;
const seriesSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': seriesUrl,
  name: seriesData.name,
  description: seriesData.description,
  url: seriesUrl,
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: episodes.length,
    itemListElement: episodes.map((v, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'VideoObject',
        name: v.title,
        description: v.description,
        thumbnailUrl: videoThumbnail(v),
        contentUrl: `https://www.youtube.com/watch?v=${v.youtubeId}`,
        embedUrl: `https://www.youtube.com/embed/${v.youtubeId}`,
        uploadDate: v.publishedDate,
        url: `${BASE_URL}/videos/${v.slug}/`,
      },
    })),
  },
};
---

<Layout
  title={`${seriesData.name} — Odyssey Homes Videos`}
  description={seriesData.description}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(seriesSchema)}></script>
    <Breadcrumbs />
  </Fragment>
  <Header />

  <!-- Series hero -->
  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-24">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">
        Tutorial Series · {episodes.length} {episodes.length === 1 ? 'episode' : 'episodes'}
      </p>
      <h1 class="mt-4 text-3xl lg:text-5xl font-bold tracking-tight text-white max-w-3xl">{seriesData.name}</h1>
      <p class="mt-6 text-lg lg:text-xl text-odyssey-cream/85 max-w-3xl leading-relaxed">
        {seriesData.longDescription || seriesData.description}
      </p>
    </div>
  </section>

  {!hasEpisodes && (
    <section class="bg-odyssey-bone">
      <div class="max-w-3xl mx-auto px-6 lg:px-8 py-24 text-center">
        <h2 class="text-2xl font-semibold text-odyssey-charcoal">Episodes coming soon.</h2>
        <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
          We're recording. Check back here or subscribe on YouTube to catch new episodes as they drop.
        </p>
        <a href="/videos/" class="mt-8 inline-block text-sm font-semibold uppercase tracking-wider text-odyssey-accent hover:text-odyssey-accent-deep">
          ← Browse all videos
        </a>
      </div>
    </section>
  )}

  {hasEpisodes && (
    <section class="bg-odyssey-bone">
      <div class="max-w-5xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
        <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Episodes</p>
        <h2 class="mt-3 text-2xl lg:text-3xl font-semibold tracking-tight text-odyssey-charcoal">Watch in order — or skip to what you need.</h2>

        <div class="mt-10 space-y-4">
          {episodes.map((video, i) => (
            <a href={`/videos/${video.slug}/`} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
              <div class="grid sm:grid-cols-[280px,1fr] gap-0">
                <div class="aspect-video sm:aspect-auto bg-odyssey-charcoal relative overflow-hidden">
                  <img src={videoThumbnail(video)} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  <div class="absolute inset-0 flex items-center justify-center">
                    <div class="w-14 h-14 bg-odyssey-accent rounded-full flex items-center justify-center opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all">
                      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="white" class="ml-1"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                    </div>
                  </div>
                </div>
                <div class="p-6 flex flex-col justify-center">
                  <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent">
                    Episode {video.series?.episode || i + 1}
                  </p>
                  <h3 class="mt-2 text-xl font-semibold text-odyssey-charcoal leading-tight">{video.title}</h3>
                  <p class="mt-2 text-sm text-odyssey-stone-dark leading-relaxed">{video.description}</p>
                  <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-odyssey-accent">Watch →</p>
                </div>
              </div>
            </a>
          ))}
        </div>

        <div class="mt-12 text-center">
          <a href="/videos/" class="text-sm font-semibold uppercase tracking-wider text-odyssey-accent hover:text-odyssey-accent-deep">
            ← Browse all videos
          </a>
        </div>
      </div>
    </section>
  )}

  <Footer />
</Layout>
