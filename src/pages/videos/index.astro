---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { videos, videoThumbnail, CATEGORY_LABELS, type VideoCategory } from '../../data/videos';
import { activeSeries, videosInSeries, standaloneVideos } from '../../data/series';
import { site } from '../../data/site';

const seriesList = activeSeries();
const standalone = standaloneVideos();
const hasAnything = videos.length > 0;

// Group standalone videos by category
const byCategory: Record<VideoCategory, typeof videos> = {} as any;
standalone.forEach(v => {
  if (!byCategory[v.category]) byCategory[v.category] = [];
  byCategory[v.category].push(v);
});
const categoriesWithVideos = (Object.keys(byCategory) as VideoCategory[]).filter(c => byCategory[c].length > 0);
---

<Layout
  title="Videos — Behind the Build at Odyssey Homes"
  description="Tutorial series, plan walkthroughs, community tours, cost transparency, and behind-the-scenes from Odyssey Homes — Eastern Idaho's new-construction semi-custom home builder."
>
  <Fragment slot="head">
    <Breadcrumbs />
  </Fragment>
  <Header />

  <!-- Hero -->
  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Videos</p>
      <h1 class="mt-4 text-4xl lg:text-6xl font-bold tracking-tight text-white">
        Behind the build.
      </h1>
      <p class="mt-6 text-lg lg:text-xl text-odyssey-cream/85 max-w-3xl leading-relaxed">
        Tutorial series for our clients, plan walkthroughs, community drone tours, honest cost conversations, and a look at what actually happens on an Odyssey job site.
      </p>
      <div class="mt-8">
        <a
          href={site.social.youtube}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 bg-white/10 hover:bg-white/20 backdrop-blur text-white font-semibold py-3 px-6 rounded border border-white/20 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
          </svg>
          Subscribe on YouTube
        </a>
      </div>
    </div>
  </section>

  {!hasAnything && (
    <section class="bg-odyssey-bone">
      <div class="max-w-3xl mx-auto px-6 lg:px-8 py-24 text-center">
        <div class="w-20 h-20 mx-auto bg-odyssey-accent/10 rounded-full flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-odyssey-accent">
            <polygon points="5 3 19 12 5 21 5 3"/>
          </svg>
        </div>
        <h2 class="mt-8 text-3xl font-semibold text-odyssey-charcoal">Videos rolling out soon.</h2>
        <p class="mt-4 text-lg text-odyssey-stone-dark leading-relaxed">
          Curtis is recording. Plan walkthroughs, community tours, cost-transparency Q&A, and on-the-job-site footage — all coming.
        </p>
      </div>
    </section>
  )}

  {seriesList.length > 0 && (
    <section class="bg-odyssey-bone">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-24">
        <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Tutorial Series</p>
        <h2 class="mt-3 text-3xl lg:text-4xl font-semibold tracking-tight text-odyssey-charcoal">Step-by-step, in order.</h2>
        <p class="mt-4 text-odyssey-stone-dark leading-relaxed max-w-3xl">
          Multi-episode walkthroughs designed to take you from zero to confident with the tools every Odyssey client uses.
        </p>

        <div class="mt-12 grid md:grid-cols-2 gap-8">
          {seriesList.map(s => {
            const episodes = videosInSeries(s.slug);
            const featured = episodes[0];
            return (
              <a href={`/videos/series/${s.slug}/`} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                <div class="aspect-video bg-odyssey-charcoal relative overflow-hidden">
                  <img src={videoThumbnail(featured)} alt={s.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                  <div class="absolute inset-0 bg-gradient-to-t from-odyssey-charcoal/80 to-transparent"></div>
                  <div class="absolute bottom-4 left-4 right-4">
                    <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent-light">Tutorial Series · {episodes.length} {episodes.length === 1 ? 'episode' : 'episodes'}</p>
                    <h3 class="mt-2 text-2xl font-bold text-white">{s.name}</h3>
                  </div>
                </div>
                <div class="p-6">
                  <p class="text-odyssey-stone-dark leading-relaxed">{s.description}</p>
                  <p class="mt-4 text-sm font-semibold uppercase tracking-wider text-odyssey-accent">Watch the series →</p>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}

  {categoriesWithVideos.length > 0 && (
    <section class="bg-white border-t border-odyssey-stone/15">
      <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-24">
        <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">More Videos</p>
        <h2 class="mt-3 text-3xl lg:text-4xl font-semibold tracking-tight text-odyssey-charcoal">Browse by topic.</h2>
        {categoriesWithVideos.map(category => (
          <div class="mt-14">
            <h3 class="text-2xl font-semibold text-odyssey-charcoal">{CATEGORY_LABELS[category]}</h3>
            <div class="mt-8 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {byCategory[category].map(video => (
                <a href={`/videos/${video.slug}/`} class="group block bg-odyssey-bone rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-shadow">
                  <div class="aspect-video bg-odyssey-charcoal relative overflow-hidden">
                    <img src={videoThumbnail(video)} alt={video.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
                    <div class="absolute inset-0 flex items-center justify-center">
                      <div class="w-16 h-16 bg-odyssey-accent rounded-full flex items-center justify-center opacity-90 group-hover:opacity-100 group-hover:scale-110 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="white" class="ml-1">
                          <polygon points="5 3 19 12 5 21 5 3"/>
                        </svg>
                      </div>
                    </div>
                  </div>
                  <div class="p-5">
                    <h4 class="text-lg font-semibold text-odyssey-charcoal leading-tight">{video.title}</h4>
                    <p class="mt-2 text-sm text-odyssey-stone-dark leading-relaxed line-clamp-3">{video.description}</p>
                    <p class="mt-3 text-xs font-semibold uppercase tracking-wider text-odyssey-accent">Watch →</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>
  )}

  <Footer />
</Layout>
