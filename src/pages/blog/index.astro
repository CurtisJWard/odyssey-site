---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Blog placeholder. Future posts will be authored as MDX in src/content/blog/.
// Note: the original site had three real posts plus several future-dated test posts
// from the prior maintainer. Test posts intentionally NOT migrated.
const posts = [
  {
    slug: 'how-idaho-falls-semi-custom-home-builders-adapt-homes-for-the-seasons',
    title: 'How Idaho Falls Semi-Custom Home Builders Adapt Homes for the Seasons',
    image: '/media/knxbi1x2/how-idaho-falls-semi-custom-home-builders-adapt-homes-for-the-seasons.jpg',
    summary: 'How we design and build for the realities of Eastern Idaho seasons.',
  },
  {
    slug: 'pet-friendly-semi-custom-homes',
    title: 'Pet-Friendly Semi-Custom Homes',
    image: '/media/2chl5ixs/pet-friendly-semi-custom-homes.jpeg',
    summary: 'Design considerations that make a semi-custom home work for the whole family — including the four-legged ones.',
  },
  {
    slug: 'important-topics-to-consider-when-choosing-a-semi-custom-home',
    title: 'Important Topics to Consider When Choosing a Semi-Custom Home',
    image: '/media/apljhdjq/important-topics-to-consider-when-choosing-a-semi-custom-home.jpeg',
    summary: 'A short list of the conversations every buyer should have before they sign.',
  },
];
---

<Layout title="Blog — Odyssey Homes" description="Expert advice, design ideas, and local trends from the Odyssey Homes team.">
  <Header />

  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Blog</p>
      <h1 class="mt-4 text-4xl lg:text-6xl font-bold tracking-tight text-white">Expert Advice, Design Ideas, and Local Trends</h1>
    </div>
  </section>

  <section class="bg-odyssey-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <div class="grid md:grid-cols-3 gap-8">
        {posts.map(post => (
          <div class="bg-white rounded overflow-hidden shadow-sm">
            <div class="aspect-[4/3] bg-odyssey-sand overflow-hidden">
              <img src={post.image} alt={post.title} class="w-full h-full object-cover" />
            </div>
            <div class="p-6">
              <h3 class="text-xl font-semibold text-odyssey-charcoal leading-tight">{post.title}</h3>
              <p class="mt-3 text-sm text-odyssey-stone-dark leading-relaxed">{post.summary}</p>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-12 text-sm text-odyssey-stone italic">More posts coming soon.</p>
    </div>
  </section>

  <Footer />
</Layout>
