---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { communities } from '../../data/communities';
import { specHomesByCommunity, totalAvailableSpecs, type SpecHomeStatus } from '../../data/specHomes';
import { plans } from '../../data/plans';
import { specPhotos } from '../../data/specPhotos';

const statusLabels: Record<SpecHomeStatus, string> = {
  'available': 'Available',
  'reserved': 'Reserved',
  'under-contract': 'Under Contract',
  'sold': 'Sold',
};

const planBySlug = new Map(plans.map(p => [p.slug, p]));

function formatPrice(price?: number): string {
  if (price === undefined) return 'Coming Soon';
  return '$' + price.toLocaleString(undefined, { maximumFractionDigits: 0 });
}

const totalAvailable = totalAvailableSpecs();
---

<Layout
  title="Quick Move-Ins — Odyssey Homes"
  description="Move into a new Odyssey home sooner. Browse spec homes in progress across Eastern Idaho — Idaho Falls, Ammon, Rigby, Rexburg, Shelley, and Blackfoot. Claim one at any stage and customize what you can."
>
  <Fragment slot="head">
    <Breadcrumbs />
  </Fragment>
  <Header />

  <!-- Hero -->
  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Quick Move-Ins</p>
      <h1 class="mt-4 text-4xl lg:text-6xl font-bold tracking-tight text-white">Move in sooner.</h1>
      <p class="mt-6 text-lg lg:text-xl text-odyssey-cream/85 max-w-3xl leading-relaxed">
        Homes we're already building across Eastern Idaho. Claim one at any stage — earlier = more finish customization, later = move in sooner. {totalAvailable > 0 && (
          <span class="font-semibold text-white">{totalAvailable} available right now.</span>
        )}
      </p>
    </div>
  </section>

  <!-- Per-community spec inventory — card layout -->
  {communities.map((community) => {
    const specs = specHomesByCommunity(community.slug);
    if (specs.length === 0) return null;
    return (
      <section class="bg-odyssey-bone" id={community.slug}>
        <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
          <div class="flex items-center justify-between gap-4 flex-wrap mb-10">
            <h2 class="text-3xl lg:text-4xl font-semibold text-odyssey-charcoal">{community.name}</h2>
            <span class="text-sm text-odyssey-stone uppercase tracking-wider font-semibold">{specs.filter(s => s.status === 'available').length} available</span>
          </div>

          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {specs.map((spec) => {
              const plan = planBySlug.get(spec.planSlug);
              const planLive = plan?.status === 'live';
              const photo = specPhotos[spec.address];
              return (
                <div class={`bg-white rounded-lg shadow-sm overflow-hidden flex flex-col ${spec.status === 'sold' ? 'opacity-60' : ''}`}>
                  <!-- Photo or placeholder -->
                  <div class="aspect-video bg-odyssey-sand overflow-hidden">
                    {photo ? (
                      <img
                        src={photo}
                        alt={`${spec.address} — home under construction`}
                        class="w-full h-full object-cover cursor-zoom-in hover:scale-105 transition-transform duration-300"
                        loading="lazy"
                        data-lightbox={photo}
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-odyssey-stone/40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
                          <polyline stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" points="9 22 9 12 15 12 15 22" />
                        </svg>
                      </div>
                    )}
                  </div>

                  <!-- Card body -->
                  <div class="p-5 flex flex-col flex-1">
                    <div class="flex items-start justify-between gap-3 mb-4">
                      <div>
                        <p class="font-semibold text-odyssey-charcoal text-lg leading-snug">{spec.address}</p>
                        <p class="text-sm text-odyssey-stone-dark mt-0.5">{spec.lotNumber}</p>
                      </div>
                      <span class={
                        spec.status === 'available'      ? 'shrink-0 inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-accent text-white' :
                        spec.status === 'reserved'       ? 'shrink-0 inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-sand text-odyssey-charcoal' :
                        spec.status === 'under-contract' ? 'shrink-0 inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-stone text-white' :
                        'shrink-0 inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-stone/30 text-odyssey-stone-dark'
                      }>{statusLabels[spec.status]}</span>
                    </div>

                    <div class="grid grid-cols-2 gap-x-4 gap-y-3 text-sm flex-1">
                      <div>
                        <p class="text-xs uppercase tracking-wider text-odyssey-stone mb-0.5">Floor Plan</p>
                        {planLive ? (
                          <a href={`/semi-custom-home-floor-plans/${spec.planSlug}/`} class="text-odyssey-accent hover:underline font-semibold">{plan?.name}</a>
                        ) : (
                          <p class="font-semibold text-odyssey-charcoal">{plan?.name || (spec.planSlug ? spec.planSlug : 'TBD')}</p>
                        )}
                        {plan?.totalSqFt && plan?.beds && (
                          <p class="text-xs text-odyssey-stone mt-0.5">{plan.totalSqFt.toLocaleString()} sf · {plan.beds}br · {plan.baths}ba</p>
                        )}
                      </div>
                      <div>
                        <p class="text-xs uppercase tracking-wider text-odyssey-stone mb-0.5">Completion</p>
                        <p class="font-semibold text-odyssey-stone-dark">{spec.tentativeCompletion}</p>
                      </div>
                      <div class="col-span-2">
                        <p class="text-xs uppercase tracking-wider text-odyssey-stone mb-0.5">Price</p>
                        <p class="font-semibold text-odyssey-charcoal text-base">{formatPrice(spec.price)}</p>
                      </div>
                    </div>

                    {spec.notes && (
                      <p class="mt-3 text-xs text-odyssey-stone italic">{spec.notes}</p>
                    )}

                    {spec.status === 'available' && (
                      <a href="/lets-talk/" class="mt-5 inline-block text-center bg-odyssey-accent hover:bg-odyssey-accent-deep text-white text-sm font-semibold py-2.5 px-4 rounded transition-colors">
                        Get info →
                      </a>
                    )}
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </section>
    );
  })}

  <!-- "Don't see what you want" CTA -->
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl lg:text-4xl font-semibold text-odyssey-charcoal">Don't see the right home?</h2>
      <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
        New specs go in the ground regularly. Tell us what you're looking for — location, plan, timeline — and we'll let you know what's coming next.
      </p>
      <a href="/lets-talk/" class="mt-8 inline-block bg-odyssey-accent hover:bg-odyssey-accent-deep text-white font-semibold py-3 px-7 rounded transition-colors">
        Tell us what you're looking for
      </a>
    </div>
  </section>

  <!-- Contact form -->
  <section class="bg-odyssey-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <ContactForm
        heading="Want a Quick Move-In?"
        intro="We'll send you a current list of available specs and timelines."
      />
    </div>
  </section>

  <Footer />

  <!-- Lightbox -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90" role="dialog" aria-modal="true">
    <button id="lightbox-close" aria-label="Close" class="absolute top-4 right-4 text-white/80 hover:text-white transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <img id="lightbox-img" src="" alt="" class="max-w-[90vw] max-h-[90vh] object-contain rounded shadow-2xl" />
  </div>

  <script>
    const lightbox = document.getElementById('lightbox') as HTMLElement;
    const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;

    // Open on any spec photo click
    document.querySelectorAll('[data-lightbox]').forEach(el => {
      el.addEventListener('click', () => {
        const src = (el as HTMLElement).dataset.lightbox!;
        const alt = (el as HTMLImageElement).alt || '';
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        document.body.style.overflow = 'hidden';
      });
    });

    // Close on backdrop or button click
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || e.target === document.getElementById('lightbox-close')) {
        closeLightbox();
      }
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeLightbox();
    });

    function closeLightbox() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      document.body.style.overflow = '';
    }
  </script>
</Layout>
