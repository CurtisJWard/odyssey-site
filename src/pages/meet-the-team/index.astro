---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { team } from '../../data/team';
---

<Layout title="Meet the Team — Odyssey Homes" description="Meet the Odyssey Homes team — builders, designers, sales specialists, and field leaders bringing your semi-custom home to life.">
  <Header />

  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">About</p>
      <h1 class="mt-4 text-4xl lg:text-6xl font-bold tracking-tight text-white">Meet the Team</h1>
      <p class="mt-6 text-lg text-odyssey-cream/85 max-w-2xl leading-relaxed">
        When you work with Odyssey Homes you get the undivided attention of our professional draftsman, designer, builders, and agents — fully involved from estimating through close-out.
      </p>
    </div>
  </section>

  <section class="bg-odyssey-bone">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {team.map(m => (
          <div class="bg-white rounded overflow-hidden shadow-sm">
            <div class="aspect-square bg-odyssey-sand overflow-hidden">
              <img src={m.image} alt={m.name} class="w-full h-full object-cover" />
            </div>
            <div class="p-5">
              <h3 class="text-lg font-semibold text-odyssey-charcoal">{m.name}</h3>
              <p class="text-sm text-odyssey-accent font-semibold">{m.title}</p>
              {m.experience && (
                <p class="mt-1 text-xs text-odyssey-stone uppercase tracking-wider">{m.experience}</p>
              )}
              <p class="mt-3 text-sm text-odyssey-stone-dark leading-relaxed">{m.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</Layout>
