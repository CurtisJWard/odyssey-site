---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { communities } from '../../data/communities';
import { lotsByCommunity, lotCountByStatus, type Lot, type LotStatus } from '../../data/lots';
import { plans } from '../../data/plans';
import { site } from '../../data/site';

const statusLabels: Record<LotStatus, string> = {
  'available': 'Available',
  'spec-in-progress': 'Spec in Progress',
  'reserved': 'Reserved',
  'under-contract': 'Under Contract',
  'sold': 'Sold',
};

// Map plan slugs to display names for the "Fits plans:" column
const planNameBySlug = new Map(plans.map(p => [p.slug, p.name]));

// Only show communities on this page if they actually have lots available.
// Communities that are only spec-home destinations (The Parks, Moser Estates)
// don't belong here — they live solely on /quick-move-ins/.
const communitiesWithLots = communities.filter(c => lotsByCommunity(c.slug).length > 0);

function formatPrice(price?: number): string {
  if (price === undefined) return 'Coming Soon';
  return '$' + price.toLocaleString(undefined, { maximumFractionDigits: 0 });
}

function formatSize(lot: Lot): string {
  if (lot.acres !== undefined) return `${lot.acres.toFixed(2)} ac`;
  if (lot.sqFt !== undefined) return `${lot.sqFt.toLocaleString()} sq ft`;
  return '—';
}
---

<Layout
  title="Available Lots — Odyssey Homes"
  description="Land is getting harder to find in Eastern Idaho. See available homesites in Granite Creek, Hawks Landing, and Sand Creek Estates."
>
  <Fragment slot="head">
    <Breadcrumbs />
  </Fragment>
  <Header />

  <!-- Hero -->
  <section class="bg-odyssey-charcoal text-odyssey-cream">
    <div class="max-w-5xl mx-auto px-6 lg:px-8 py-20 lg:py-28">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent-light uppercase">Available Homesites</p>
      <h1 class="mt-4 text-4xl lg:text-6xl font-bold tracking-tight text-white">Land is getting harder to find.</h1>
      <p class="mt-6 text-lg lg:text-xl text-odyssey-cream/85 max-w-3xl leading-relaxed">
        Odyssey Homes has homesites across multiple Eastern Idaho communities — Granite Creek, Hawks Landing, and Sand Creek Estates coming soon. Find your spot below.
      </p>
    </div>
  </section>

  <!-- Quick stats (only communities with lots) -->
  <section class="bg-white border-b border-odyssey-stone/15">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-8">
      <div class={`grid grid-cols-2 md:grid-cols-${Math.min(communitiesWithLots.length, 4)} gap-6 text-center`}>
        {communitiesWithLots.map(c => {
          const counts = lotCountByStatus(c.slug);
          return (
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-stone">{c.name}</p>
              <p class="mt-2 text-3xl font-bold text-odyssey-charcoal">{counts.available}</p>
              <p class="text-sm text-odyssey-stone-dark">lots available</p>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Per-community sections -->
  {communitiesWithLots.map((community) => {
    const communityLots = lotsByCommunity(community.slug);
    const isComingSoon = community.status === 'coming-soon';
    return (
      <section class="bg-odyssey-bone" id={community.slug}>
        <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
          <div class="grid lg:grid-cols-3 gap-10 items-start">

            <!-- Story column -->
            <div class="lg:col-span-1">
              <a href={`/available-lots/${community.slug}/`} class="group block">
                <div class="aspect-[4/3] bg-odyssey-sand rounded overflow-hidden mb-6">
                  <img src={community.image} alt={community.name} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                </div>
                <div class="flex items-center justify-between gap-3 mb-3">
                  <h2 class="text-3xl font-semibold text-odyssey-charcoal group-hover:text-odyssey-accent transition-colors">{community.name}</h2>
                  {isComingSoon && (
                    <span class="text-xs font-semibold uppercase tracking-widest text-white bg-odyssey-accent px-3 py-1 rounded">Coming Soon</span>
                  )}
                </div>
                <p class="text-odyssey-stone-dark leading-relaxed">{community.description}</p>
                <p class="mt-4 text-sm font-semibold text-odyssey-accent uppercase tracking-wider">
                  Explore {community.name} →
                </p>
              </a>
            </div>

            <!-- Inventory column -->
            <div class="lg:col-span-2">
              {isComingSoon ? (
                <div class="bg-white rounded p-8 lg:p-10 border-2 border-dashed border-odyssey-stone/30">
                  <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent">Pre-list interest</p>
                  <h3 class="mt-2 text-2xl font-semibold text-odyssey-charcoal">Be first in line for Sand Creek Estates</h3>
                  <p class="mt-3 text-odyssey-stone-dark leading-relaxed">
                    Lots haven't released yet. Get on the interest list and we'll reach out the moment they do.
                  </p>
                  <a href="/lets-talk/" class="mt-6 inline-block bg-odyssey-accent hover:bg-odyssey-accent-deep text-white font-semibold py-3 px-6 rounded transition-colors">
                    Add me to the list
                  </a>
                </div>
              ) : communityLots.length === 0 ? (
                <div class="bg-white rounded p-8 border border-odyssey-stone/20">
                  <p class="text-odyssey-stone-dark">No lots currently listed. Contact us — we may have lots not yet on the site.</p>
                </div>
              ) : (
                <div class="bg-white rounded shadow-sm overflow-hidden">
                  <!-- Desktop table -->
                  <div class="hidden md:block">
                    <table class="w-full text-sm">
                      <thead class="bg-odyssey-charcoal text-odyssey-cream">
                        <tr>
                          <th class="px-4 py-3 text-left font-semibold uppercase tracking-wider text-xs">Lot</th>
                          <th class="px-4 py-3 text-left font-semibold uppercase tracking-wider text-xs">Address</th>
                          <th class="px-4 py-3 text-left font-semibold uppercase tracking-wider text-xs">Size</th>
                          <th class="px-4 py-3 text-left font-semibold uppercase tracking-wider text-xs">Price</th>
                          <th class="px-4 py-3 text-left font-semibold uppercase tracking-wider text-xs">Status</th>
                          <th class="px-4 py-3 text-right font-semibold uppercase tracking-wider text-xs"></th>
                        </tr>
                      </thead>
                      <tbody>
                        {communityLots.map((lot, idx) => {
                          const dim = lot.status === 'sold';
                          const rowBg = idx % 2 === 0 ? 'bg-white' : 'bg-odyssey-bone';
                          return (
                            <tr class={`${rowBg} ${dim ? 'opacity-60' : ''} border-t border-odyssey-stone/10`}>
                              <td class="px-4 py-3 font-semibold text-odyssey-charcoal whitespace-nowrap">{lot.lotNumber}</td>
                              <td class="px-4 py-3 text-odyssey-stone-dark">{lot.address || '—'}</td>
                              <td class="px-4 py-3 text-odyssey-stone-dark whitespace-nowrap">{formatSize(lot)}</td>
                              <td class="px-4 py-3 text-odyssey-charcoal font-semibold whitespace-nowrap">{formatPrice(lot.price)}</td>
                              <td class="px-4 py-3 whitespace-nowrap">
                                <span class={
                                  lot.status === 'available' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-accent text-white' :
                                  lot.status === 'spec-in-progress' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-yellow-200 text-yellow-900' :
                                  lot.status === 'reserved' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-sand text-odyssey-charcoal' :
                                  lot.status === 'under-contract' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-stone text-white' :
                                  'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-stone/30 text-odyssey-stone-dark'
                                }>
                                  {statusLabels[lot.status]}
                                </span>
                              </td>
                              <td class="px-4 py-3 text-right whitespace-nowrap">
                                {lot.status === 'available' && (
                                  <a href="/lets-talk/" class="text-xs font-semibold uppercase tracking-wider text-odyssey-accent hover:text-odyssey-accent-deep">Get info →</a>
                                )}
                              </td>
                            </tr>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>

                  <!-- Mobile cards -->
                  <div class="md:hidden divide-y divide-odyssey-stone/10">
                    {communityLots.map(lot => {
                      const dim = lot.status === 'sold';
                      return (
                        <div class={`p-5 ${dim ? 'opacity-60' : ''}`}>
                          <div class="flex items-start justify-between gap-3">
                            <div>
                              <p class="font-semibold text-odyssey-charcoal text-lg">{lot.lotNumber}</p>
                              {lot.address && <p class="text-sm text-odyssey-stone-dark">{lot.address}</p>}
                            </div>
                            <span class={
                              lot.status === 'available' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-accent text-white' :
                              lot.status === 'reserved' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-sand text-odyssey-charcoal' :
                              lot.status === 'under-contract' ? 'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-stone text-white' :
                              'inline-block px-2.5 py-1 rounded text-xs font-semibold bg-odyssey-stone/30 text-odyssey-stone-dark'
                            }>
                              {statusLabels[lot.status]}
                            </span>
                          </div>
                          <div class="mt-3 grid grid-cols-2 gap-3 text-sm">
                            <div>
                              <p class="text-xs uppercase tracking-wider text-odyssey-stone">Size</p>
                              <p class="text-odyssey-stone-dark">{formatSize(lot)}</p>
                            </div>
                            <div>
                              <p class="text-xs uppercase tracking-wider text-odyssey-stone">Price</p>
                              <p class="font-semibold text-odyssey-charcoal">{formatPrice(lot.price)}</p>
                            </div>
                          </div>
                          {lot.notes && (
                            <p class="mt-3 text-xs text-odyssey-stone italic">{lot.notes}</p>
                          )}
                          {lot.status === 'available' && (
                            <a href="/lets-talk/" class="mt-4 inline-block text-xs font-semibold uppercase tracking-wider text-odyssey-accent">Get info →</a>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              )}

            </div>
          </div>
        </div>
      </section>
    );
  })}

  <!-- "Don't see what you want" CTA -->
  <section class="bg-white">
    <div class="max-w-3xl mx-auto px-6 lg:px-8 py-20 text-center">
      <h2 class="text-3xl lg:text-4xl font-semibold text-odyssey-charcoal">Don't see what you want?</h2>
      <p class="mt-4 text-odyssey-stone-dark leading-relaxed">
        Inventory changes weekly. We sometimes have lots not yet on the site — and we have relationships with developers across Eastern Idaho. Tell us what you're looking for.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/lets-talk/" class="inline-block bg-odyssey-accent hover:bg-odyssey-accent-deep text-white font-semibold py-3 px-7 rounded transition-colors">
          Tell us what you're looking for
        </a>
        <a href={site.phoneHref} class="inline-block bg-white hover:bg-odyssey-sand text-odyssey-charcoal font-semibold py-3 px-7 rounded border border-odyssey-stone/30 transition-colors">
          Call {site.phone}
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>
