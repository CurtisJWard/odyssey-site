---
import { site } from '../data/site';
import VisitUs from './VisitUs.astro';
import MembershipBadges from './MembershipBadges.astro';
---

<footer class="bg-odyssey-charcoal text-odyssey-cream">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 grid md:grid-cols-5 gap-10">
    <div class="md:col-span-2">
      <img src="/images/odysseyhomes-horizontallogo-white.png" alt={site.name} class="h-16 w-auto mb-6" />
      <p class="text-sm leading-relaxed text-odyssey-cream/80 max-w-md">
        Your trusted Eastern Idaho new construction home builder. Serving Idaho Falls, Ammon, Rigby, Rexburg, Shelley, and Blackfoot. We build new homes only.
      </p>
    </div>

    <div>
      <VisitUs variant="footer" />
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent-light">Service Area</p>
      <p class="mt-3 text-sm leading-relaxed text-odyssey-cream/80">
        Idaho Falls · Ammon<br />
        Rigby · Rexburg<br />
        Shelley · Blackfoot<br />
        <span class="text-xs text-odyssey-cream/60">New construction only</span>
      </p>
    </div>

    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-accent-light">Contact</p>
      <p class="mt-3 text-sm leading-relaxed text-odyssey-cream/80">
        <a href={site.phoneHref} class="hover:text-odyssey-accent-light transition-colors">{site.phone}</a><br />
        <a href={site.emailHref} class="hover:text-odyssey-accent-light transition-colors">{site.email}</a>
      </p>
      <p class="mt-5 text-xs font-semibold uppercase tracking-widest text-odyssey-accent-light">For Clients</p>
      <p class="mt-3 text-sm">
        <a href={site.clientPortalUrl} target="_blank" rel="noopener" class="text-odyssey-cream/80 hover:text-odyssey-accent-light transition-colors">
          Client Portal Login →
        </a>
      </p>
      <div class="mt-5 flex gap-4">
        <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="text-odyssey-cream/70 hover:text-odyssey-accent-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M9.198 21.5h4v-8.01h3.604l.396-3.98h-4V7.5a1 1 0 0 1 1-1h3v-4h-3a5 5 0 0 0-5 5v2.01h-2l-.396 3.98h2.396V21.5z"/></svg>
        </a>
        <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="text-odyssey-cream/70 hover:text-odyssey-accent-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="text-odyssey-cream/70 hover:text-odyssey-accent-light transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Membership badges row — trust marks for E-E-A-T + buyer confidence -->
  <div class="border-t border-odyssey-cream/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-6 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <p class="text-xs font-semibold uppercase tracking-widest text-odyssey-cream/60">Proud Member</p>
      <MembershipBadges variant="footer" />
    </div>
  </div>

  <div class="border-t border-odyssey-cream/10">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-5 text-xs text-odyssey-cream/60 flex flex-col md:flex-row justify-between gap-2">
      <p>© {new Date().getFullYear()} {site.name}. All rights reserved.</p>
      <p><a href="/terms-conditions/" class="hover:text-odyssey-accent-light transition-colors">Terms & Conditions</a></p>
    </div>
  </div>
</footer>
