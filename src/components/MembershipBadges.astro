---
/**
 * MembershipBadges — EIHBA + NAHB trust marks.
 *
 * Two variants:
 *   variant="footer" → compact, white-card-on-dark, side-by-side, for the
 *                      site footer next to social icons.
 *   variant="full"   → large color badges with descriptive text + outbound
 *                      links, for a dedicated "Memberships & Associations"
 *                      section on /meet-the-team/ (or wherever).
 *
 * Add new memberships to the BADGES array below — both variants render
 * conditionally based on what's defined.
 */

interface Props {
  variant: 'footer' | 'full';
}
const { variant } = Astro.props;

interface Badge {
  slug: string;
  name: string;          // Full association name
  short: string;         // Short name shown in tight contexts
  image: string;         // path under /public/
  imageDark?: string;    // optional dark-bg variant
  url: string;           // outbound link
  description: string;   // copy for the full variant
}

const BADGES: Badge[] = [
  {
    slug: 'eihba',
    name: 'Eastern Idaho Home Builders Association',
    short: 'EIHBA',
    image: '/media/badges/eihba.webp',
    url: 'https://eastidahobuilders.com/',
    description: "Odyssey Homes is a proud member of the Eastern Idaho Home Builders Association — the regional chapter representing residential builders across Bonneville, Bingham, Jefferson, and Madison counties. Membership signals our commitment to building-code best practices, industry standards, and the local construction community.",
  },
  {
    slug: 'nahb',
    name: 'National Association of Home Builders',
    short: 'NAHB',
    image: '/media/badges/nahb.png',
    imageDark: '/media/badges/nahb-white.png',
    url: 'https://www.nahb.org/',
    description: "Odyssey Homes is also a member of the National Association of Home Builders — the country's largest trade association representing home builders, remodelers, and the residential construction industry. NAHB sets the national standards we hold ourselves to.",
  },
];
---

{variant === 'footer' && (
  <div class="flex flex-wrap gap-3 items-center">
    {BADGES.map(badge => (
      <a
        href={badge.url}
        target="_blank"
        rel="noopener"
        title={`${badge.name} — visit website`}
        aria-label={`${badge.name} — visit website`}
        class="inline-flex items-center bg-white rounded px-3 py-2 hover:bg-odyssey-cream transition-colors"
      >
        <img
          src={badge.image}
          alt={`Member of ${badge.short}`}
          class="h-8 w-auto"
          loading="lazy"
        />
      </a>
    ))}
  </div>
)}

{variant === 'full' && (
  <section class="bg-odyssey-bone border-y border-odyssey-stone/15">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-16 lg:py-20">
      <p class="text-sm font-semibold tracking-[0.2em] text-odyssey-accent uppercase">Memberships & Associations</p>
      <h2 class="mt-3 text-3xl lg:text-4xl font-semibold tracking-tight text-odyssey-charcoal">Standing with the industry.</h2>
      <p class="mt-4 text-odyssey-stone-dark leading-relaxed max-w-3xl">
        We're active members of the local + national homebuilding community — which keeps us accountable to industry standards, plugged into building-code updates, and connected to the network of trades and suppliers that make every Odyssey home possible.
      </p>

      <div class="mt-12 grid md:grid-cols-2 gap-8">
        {BADGES.map(badge => (
          <a
            href={badge.url}
            target="_blank"
            rel="noopener"
            class="block bg-white rounded-lg p-7 shadow-sm hover:shadow-md transition-shadow"
          >
            <div class="h-24 flex items-center">
              <img
                src={badge.image}
                alt={`${badge.name} logo`}
                class="max-h-24 w-auto"
                loading="lazy"
              />
            </div>
            <h3 class="mt-6 text-xl font-semibold text-odyssey-charcoal">{badge.name}</h3>
            <p class="mt-3 text-sm text-odyssey-stone-dark leading-relaxed">{badge.description}</p>
            <p class="mt-4 text-xs font-semibold uppercase tracking-wider text-odyssey-accent">
              Visit {badge.short} website →
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
)}
